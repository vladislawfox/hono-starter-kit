NODE_ENV=development
PORT=3000

# LOG_LEVEL defaults to debug (dev) / info (prod) / silent (test).
# Uncomment to override.
# LOG_LEVEL=debug

# Required. Match the port in docker-compose.yml (25572 to avoid conflict with host Postgres).
DATABASE_URL=postgresql://starter:devpass@localhost:25572/starter

# Frontend origin used for CORS. 5173 is Vite's default — change to match your frontend dev server.
# In production, set this to your actual frontend URL — wildcard not allowed with credentials.
FRONTEND_URL=http://localhost:5173
