# Auto-loaded by Bun when NODE_ENV=test (set by the `test` script in package.json).
# Without this file, env validation in src/config/env.ts crashes at module load
# because DATABASE_URL is required — and that crash cascades into "Cannot access
# rootLogger before initialization" errors across every test that imports it.
#
# Points at the same docker-compose Postgres dev uses (port 25572). Integration
# tests truncate their tables in beforeEach (see CLAUDE.md "Testing"), so dev
# rows in those tables won't survive a test run — bring the stack up before
# running tests: `bun run docker:up`.
#
# CI ignores this file because the workflow `env:` block sets DATABASE_URL
# externally (process env beats every .env file in Bun's resolution order).
DATABASE_URL=postgresql://starter:devpass@localhost:25572/starter
